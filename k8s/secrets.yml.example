# Copy this file to secrets.yml and fill in your values.
# DO NOT commit secrets.yml to git!
#
# To create base64 encoded values:
#   echo -n 'your-value' | base64

apiVersion: v1
kind: Secret
metadata:
  name: starlight-secrets
  namespace: starlight
type: Opaque
data:
  # echo -n 'your-gemini-api-key' | base64
  gemini-api-key: CHANGEME==
  # echo -n 'starlight' | base64
  postgres-user: c3RhcmxpZ2h0
  # echo -n 'your-postgres-password' | base64
  postgres-password: CHANGEME==
  # echo -n 'postgresql://starlight:password@postgres:5432/starlight' | base64
  database-url: CHANGEME==
  # echo -n 'your-worker-auth-token' | base64
  worker-auth-token: CHANGEME==
