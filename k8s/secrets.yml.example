# Copy this file to secrets.yml and fill in your values.
# DO NOT commit secrets.yml to git!
#
# To create base64 encoded values:
#   echo -n 'your-value' | base64

apiVersion: v1
kind: Secret
metadata:
  name: starlight-secrets
  namespace: starlight
type: Opaque
data:
  # echo -n 'your-gemini-api-key' | base64
  gemini-api-key: CHANGEME==
