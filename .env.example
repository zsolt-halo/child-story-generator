# Google Gemini API (for text generation + image generation)
# GEMINI_API_KEY=your-gemini-api-key

# PostgreSQL — remote k8s instance (default, shared state)
# DATABASE_URL=postgresql://starlight:password@192.168.86.45:30433/starlight
# PostgreSQL — local docker (use with: docker compose --profile offline up)
# DATABASE_URL=postgresql://starlight:starlight@localhost:5432/starlight

# OpenTelemetry — "otlp" (production/docker), "console" (debug), "none" (disabled)
# OTEL_EXPORTER=none
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=starlight-backend

# Animation: "local" (GPU on this machine), "remote" (pull-based worker), "auto" (detect)
# ANIMATION_MODE=auto
# Auth token for remote animation worker (must match worker's WORKER_TOKEN)
# WORKER_AUTH_TOKEN=
